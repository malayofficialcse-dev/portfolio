<?xml version="1.0" encoding="utf-8"?>
<!--
  Azure App Service web.config for Next.js frontend.
  Routes all requests through iisnode to the Next.js server.
  Next.js must be started with "next start" (production mode).
-->
<configuration>
  <system.webServer>

    <handlers>
      <!-- Point to a small custom server entry if needed, or use next start via startup command -->
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Exclude Next.js static files and image optimizer from rewriting -->
        <rule name="NextStaticFiles" stopProcessing="true">
          <match url="^_next/(.*)$" />
          <action type="Rewrite" url=".next/static/{R:1}" />
        </rule>

        <!-- All other requests route to Next.js server -->
        <rule name="NextJsApp">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="True" />
          </conditions>
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <iisnode
      node_env="%NODE_ENV%"
      nodeProcessCommandLine="node"
      watchedFiles="web.config;server.js"
      loggingEnabled="true"
      logDirectory="iisnode"
      debuggingEnabled="false"
    />

    <security>
      <requestFiltering>
        <hiddenSegments>
          <remove segment="bin" />
        </hiddenSegments>
      </requestFiltering>
    </security>

    <httpErrors existingResponse="PassThrough" />

  </system.webServer>
</configuration>
